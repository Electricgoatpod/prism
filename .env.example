# Nebius Token Factory (OpenAI-compatible)
# Get your key: https://nebius.com/services/studio-inference-service
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1
NEBIUS_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# Agent runs on a cron; default 6 AM daily
AGENT_RUN_CRON=0 6 * * *
AGENT_ENABLED=true

# Optional: fixed seed for reproducible simulated wearable data
# SIMULATOR_SEED=42
